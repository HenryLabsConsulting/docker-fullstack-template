# ============================================
# docker-fullstack-template environment config
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database ---
POSTGRES_USER=myapp_user
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=myapp_db
DATABASE_URL=postgresql://myapp_user:change_me_to_a_strong_password@db:5432/myapp_db

# --- Backend ---
FLASK_ENV=development
# Generate a real secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_to_a_random_secret_key
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend ---
VITE_API_URL=http://localhost:5000

# --- Deploy (only needed for CI/CD) ---
# DEPLOY_HOST=your-server.example.com
# DEPLOY_USER=deploy
# DEPLOY_KEY=<paste your SSH private key in GitHub Secrets, not here>
# DEPLOY_PATH=/opt/myapp
